APP_NAME=Thinkingify API
DEBUG=true

# Enables POST /auth/dev-login — a fixed "nish" test user that bypasses
# Google sign-in entirely. Separate from DEBUG on purpose. Only enable
# where you're fine with anyone who finds the login page getting a
# one-click account (sign-up is open — see below — so this mainly just
# saves going through the Google flow, it doesn't grant anything extra).
ALLOW_DEV_LOGIN=true

# Supabase Postgres — use the Transaction Pooler connection string (port 6543)
# postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Google Cloud Console -> OAuth client ID (Web application)
GOOGLE_CLIENT_ID=

# Supabase project settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=thinkingify

# Open sign-up — any Google account can sign in and gets full access, no
# allow-list. Access control is ownership-based (edit your own content),
# not role-based, for this phase.

# Comma-separated origins allowed to call this API
CORS_ORIGINS=http://localhost:4200

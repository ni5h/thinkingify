APP_NAME=Thinkingify API
DEBUG=true

# Enables POST /auth/dev-login — a fixed "nish" admin user that bypasses
# Google sign-in and the allow-list entirely. Separate from DEBUG on
# purpose. Only enable where you're fine with anyone who finds the login
# page getting one-click admin access.
ALLOW_DEV_LOGIN=true

# Supabase Postgres — use the Transaction Pooler connection string (port 6543)
# postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Google Cloud Console -> OAuth client ID (Web application)
GOOGLE_CLIENT_ID=

# Supabase project settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=thinkingify

# Comma-separated allow-lists — sign-in is rejected with 403 for any other email
ADMIN_EMAILS=
AUTHOR_EMAILS=

# Comma-separated origins allowed to call this API
CORS_ORIGINS=http://localhost:4200
